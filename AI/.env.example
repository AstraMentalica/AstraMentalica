# Primer .env (nastavite v varnem okolju, ne v repozitoriju)
OLLAMA_URL=http://localhost:11434
# Običajna pot do chat endpointa pri Ollama je /api/chat
OLLAMA_CHAT_PATH=/api/chat
# Neobvezno: če uporabljate token ali proxy, nastavite
OLLAMA_API_KEY=
# Privzeti model nastavite tukaj (npr. `llama-3.2`)
OLLAMA_MODEL=llama-3.2
# Neobvezno: več modelov loči z vejico, npr. "llama-3.2,kakar-2.2-gamma"
OLLAMA_MODELS=llama-3.2,kakar-2.2-gamma
# Če so krediti za zunanji API potekli ali želite siliti lokalni model
# nastavite FORCE_LOCAL_OLLAMA=1
FORCE_LOCAL_OLLAMA=1
