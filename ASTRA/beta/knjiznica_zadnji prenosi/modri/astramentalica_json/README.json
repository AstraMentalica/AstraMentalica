    "relikvija → entiteta": "relikvije[x].entiteta_id → entitete[id]",
    "avatar → entiteta": "avatarji[x].odklenjeni_varuhi[] → entitete[id]",
    "avatar → relikvija": "avatarji[x].aktivne_relikvije[] → relikvije[id]"
