+ * ODVISNOSTI:
+ * - render.php (lokalna spremenljivka $naslov)
+ *
+ * PREPOVEDI:
+ * - Brez <!DOCTYPE>, <html>, <head>, <body>
+ * - Brez business logike
+ *
+ * STATUS: Stabilno
+ *
+ * AVTOR: AstraMentalica Mojster
+ * ---------------------------------------------------------
+ */
+
+declare(strict_types=1);
+
+$_glavaNaslov = $naslov ?? '';
+?>
+
+<?php if ($_glavaNaslov !== ''): ?>
